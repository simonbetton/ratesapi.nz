{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "apps/api/src/index.ts",
    "apps/api/bin/scrape-car-loan-rates.ts",
    "apps/api/bin/scrape-credit-card-rates.ts",
    "apps/api/bin/scrape-mortgage-rates.ts",
    "apps/api/bin/scrape-personal-loan-rates.ts",
    "apps/api/bin/seed-local-d1.ts",
    "apps/api/bin/uptime-check.ts",
    "apps/docs/app/layout.tsx",
    "apps/docs/app/**/layout.tsx",
    "apps/docs/app/**/page.tsx",
    "apps/docs/app/api/search/route.ts",
    "apps/docs/app/llms.txt/route.ts",
    "apps/docs/content/docs/**/*.mdx",
    "apps/docs/mdx-components.tsx",
    "apps/docs/next.config.mjs",
    "apps/docs/open-next.config.ts",
    "apps/docs/source.config.ts",
    "test/api-contract.test.ts",
    "test/data-loader.test.ts",
    "test/docs-content.test.ts"
  ],
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    ".wrangler/**",
    ".next/**",
    ".open-next/**",
    ".source/**",
    ".fallow/**",
    ".agents/**",
    ".claude/**",
    ".cursor/**",
    "tsconfig.tsbuildinfo",
    "**/*.css",
    "**/*.d.ts"
  ],
  "ignoreDependencies": ["pino-pretty"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "warn",
    "private-type-leaks": "warn",
    "unused-dependencies": "warn",
    "unused-dev-dependencies": "warn",
    "unused-optional-dependencies": "warn",
    "unused-enum-members": "warn",
    "unused-class-members": "warn",
    "unresolved-imports": "error",
    "unlisted-dependencies": "error",
    "duplicate-exports": "warn",
    "circular-dependencies": "error",
    "boundary-violation": "error",
    "type-only-dependencies": "warn",
    "test-only-dependencies": "warn",
    "coverage-gaps": "off",
    "stale-suppressions": "warn"
  },
  "duplicates": {
    "enabled": true,
    "mode": "mild",
    "minTokens": 80,
    "minLines": 8,
    "threshold": 0,
    "ignoreImports": true
  },
  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 15,
    "maxCrap": 200,
    "suggestInlineSuppression": true
  },
  "production": false
}
