{
  "scripts": {
    "dev": "wrangler dev --env development src/index.ts",
    "deploy": "wrangler deploy --minify src/index.ts",
    "deploy:dry-run": "wrangler deploy --dry-run --env=\"\" --minify src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun test",
    "prepare": "husky",
    "test": "bun test",
    "scrape:mortgage": "bun run bin/scrape-mortgage-rates.ts",
    "scrape:personal": "bun run bin/scrape-personal-loan-rates.ts",
    "scrape:car": "bun run bin/scrape-car-loan-rates.ts",
    "scrape:credit": "bun run bin/scrape-credit-card-rates.ts",
    "scrape:all": "bun run bin/scrape-mortgage-rates.ts && bun run bin/scrape-personal-loan-rates.ts && bun run bin/scrape-car-loan-rates.ts && bun run bin/scrape-credit-card-rates.ts",
    "check-uptime": "bun run bin/uptime-check.ts"
  },
  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "@elysiajs/cors": "^1.4.2",
    "@sinclair/typebox": "^0.34.49",
    "cheerio": "1.1.2",
    "elysia": "^1.4.28",
    "fumadocs-core": "^16.8.5",
    "fumadocs-ui": "^16.8.5",
    "ora": "^9.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/workers-types": "^4.20260430.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "domhandler": "^5.0.3",
    "fallow": "^2.56.0",
    "husky": "^9.1.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.86.0"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  }
}
