{
  "scripts": {
    "dev": "wrangler dev --config apps/api/wrangler.toml --env development --remote",
    "dev:api:local": "bun run db:init:local && bun run db:seed:local && wrangler dev --config apps/api/wrangler.toml --env development --local",
    "dev:docs": "bun run --cwd apps/docs dev",
    "db:init:local": "bun run apps/api/bin/init-local-d1.ts",
    "db:seed:local": "bun run apps/api/bin/seed-local-d1.ts",
    "deploy": "wrangler deploy --config apps/api/wrangler.toml --minify",
    "deploy:docs": "bun run --cwd apps/docs deploy",
    "deploy:dry-run": "wrangler deploy --config apps/api/wrangler.toml --dry-run --env=\"\" --minify",
    "scrape:all:local": "D1_DATABASE_NAME=\"ratesapi-data\" D1_LOCAL=\"true\" bun run scrape:all",
    "build:docs": "bun run --cwd apps/docs source && bun run --cwd apps/docs build:cloudflare",
    "typecheck:docs": "bun run --cwd apps/docs source && tsc -p apps/docs/tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run typecheck:docs && bun test",
    "prepare": "husky",
    "test": "bun run --cwd apps/docs source && bun test",
    "scrape:mortgage": "bun run apps/api/bin/scrape-mortgage-rates.ts",
    "scrape:personal": "bun run apps/api/bin/scrape-personal-loan-rates.ts",
    "scrape:car": "bun run apps/api/bin/scrape-car-loan-rates.ts",
    "scrape:credit": "bun run apps/api/bin/scrape-credit-card-rates.ts",
    "scrape:all": "bun run apps/api/bin/scrape-mortgage-rates.ts && bun run apps/api/bin/scrape-personal-loan-rates.ts && bun run apps/api/bin/scrape-car-loan-rates.ts && bun run apps/api/bin/scrape-credit-card-rates.ts",
    "check-uptime": "bun run apps/api/bin/uptime-check.ts"
  },
  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "@elysiajs/cors": "^1.4.2",
    "@opennextjs/cloudflare": "^1.19.5",
    "@sinclair/typebox": "^0.34.49",
    "cheerio": "1.1.2",
    "elysia": "^1.4.28",
    "fumadocs-core": "^16.8.5",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.8.5",
    "next": "^16.2.4",
    "ora": "^9.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/workers-types": "^4.20260430.1",
    "@types/bun": "^1.3.13",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "domhandler": "^5.0.3",
    "fallow": "^2.56.0",
    "husky": "^9.1.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.86.0"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  }
}
